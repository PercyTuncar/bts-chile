# Config (MOCK) de la Firebase Extension "Trigger Email" (firestore-send-email) — PRD §4.6, §10.6.
# Observa la colección `mail` (que escriben las Cloud Functions vía lib/mail.ts) y despacha correos.
# Reemplazar SMTP_CONNECTION_URI y SMTP_PASSWORD por credenciales reales antes de producción.

LOCATION=us-central1
MAIL_COLLECTION=mail
SMTP_CONNECTION_URI=smtps://noreply@btschile.com@smtp.example.com:465
DEFAULT_FROM=BTS Chile 💜 <noreply@btschile.com>
DEFAULT_REPLY_TO=contacto@btschile.com
TTL_EXPIRE_TYPE=never
